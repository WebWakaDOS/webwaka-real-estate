{
  "name": "webwaka-real-estate",
  "version": "1.0.0",
  "description": "WebWaka Real Estate vertical — property listings, transactions, and agent management for Nigeria",
  "main": "index.js",
  "scripts": {
    "dev": "wrangler dev --port 5000 --ip 0.0.0.0 --local",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "vite build",
    "build:worker": "tsc -p tsconfig.build.json",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "webwaka",
    "real-estate",
    "property",
    "nigeria",
    "africa",
    "pwa",
    "offline-first"
  ],
  "author": "WebWakaDOS",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dexie": "^4.3.0",
    "hono": "^4.12.9",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.80.0"
  },
  "dependencies": {
    "@webwaka/core": "^1.3.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
